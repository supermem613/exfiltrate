{
    "name": "exfiltrate",
    "displayName": "Exfiltrate",
    "description": "Copy the current open file from a remote VS Code session (WSL, Dev Container, SSH, Codespaces) to your local filesystem with an intuitive sidebar UI",
    "version": "0.0.2",
    "publisher": "supermem613",
    "license": "MIT",
    "icon": "images/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/supermem613/exfiltrate.git"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "extensionKind": [
        "ui",
        "workspace"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "exfiltrate.copyFile",
                "title": "Exfiltrate: Copy Current File to Local"
            },
            {
                "command": "exfiltrate.showPanel",
                "title": "Exfiltrate: Open Panel",
                "icon": "$(cloud-download)"
            },
            {
                "command": "exfiltrate.showLogs",
                "title": "Exfiltrate: Show Logs",
                "icon": "$(output)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "exfiltrate-panel",
                    "title": "Exfiltrate",
                    "icon": "images/sidebar-icon.svg"
                }
            ]
        },
        "views": {
            "exfiltrate-panel": [
                {
                    "type": "webview",
                    "id": "exfiltrate.panelView",
                    "name": "Exfiltrate",
                    "icon": "$(cloud-download)"
                }
            ]
        },
        "configuration": {
            "title": "Exfiltrate",
            "properties": {
                "exfiltrate.destinationPath": {
                    "type": "string",
                    "default": "",
                    "scope": "machine",
                    "description": "Local destination folder on host machine to copy files into (e.g., C:\\Users\\YourName\\Downloads)"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "18.x",
        "@typescript-eslint/eslint-plugin": "^6.13.0",
        "@typescript-eslint/parser": "^6.13.0",
        "eslint": "^8.54.0",
        "prettier": "^3.5.1",
        "typescript": "^5.3.2"
    }
}
